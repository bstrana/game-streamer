{
  "id": "io.github.bstrana.game-streamer",
  "title": "Game Streamer",
  "author": "bstrana",
  "description": "Baseball game live display overlay manager for OBS streaming. Manage matches and generate transparent scoreboard overlays powered by WBSC live data.",
  "tagline": "Baseball scoreboard overlay for OBS streaming",
  "version": "1.0.2",
  "manifestVersion": 2,
  "minBoxVersion": "9.1.0",
  "website": "https://github.com/bstrana/game-streamer",
  "contactEmail": "support@example.com",
  "healthCheckPath": "/health",
  "httpPort": 8000,
  "addons": { "localstorage": {} },
  "env": {
    "KEYCLOAK_URL": {
      "description": "Keycloak server URL (e.g. https://auth.example.com)",
      "value": "http://localhost:8080"
    },
    "KEYCLOAK_REALM": {
      "description": "Keycloak realm name",
      "value": "game-streamer"
    },
    "KEYCLOAK_CLIENT_ID": {
      "description": "Keycloak client ID",
      "value": "game-streamer-app"
    },
    "APP_BASE_URL": {
      "description": "Public URL of this app (used for overlay link generation)",
      "value": "https://gamestreamer.example.com"
    }
  },
  "icon": "file://appicon.png",
  "iconUrl": "https://raw.githubusercontent.com/bstrana/game-streamer/main/public/appicon.png",
  "tags": ["sports", "baseball", "obs", "streaming", "overlay"],
  "mediaLinks": [
    "https://raw.githubusercontent.com/bstrana/game-streamer/main/public/appicon.png"
  ],
  "changelog": "Load runtime config from /app/data/config.env on startup; a sample file is written on first boot.",
  "packagerName": "bstrana",
  "packagerUrl": "https://github.com/bstrana"
}
